SECRET_KEY=pon_aqui_una_clave_segura
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.46
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Opcional en desarrollo. En Render normalmente se usara PostgreSQL.
