# DATABASE_URL=sqlite:///db.sqlite3
#
# Ejemplo PostgreSQL:
# DATABASE_URL=postgresql://usuario:password@host:5432/base_de_datos

CONN_MAX_AGE=60
DB_SSLMODE=require

